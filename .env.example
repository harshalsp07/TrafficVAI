# ============================================
# ITS - Intelligent Transportation System
# Environment Configuration
# ============================================

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/traffic.db
# For ClickHouse (production):
# DATABASE_URL=clickhouse://default:@localhost:8123/traffic

# --- Inference Engine ---
MODEL_PATH=./weights/yolov12n.pt
DEVICE=cpu
# Options: cpu, cuda:0, openvino
CONFIDENCE_THRESHOLD=0.5
NMS_THRESHOLD=0.45
MAX_STREAMS=4
FRAME_SKIP=1
ROBOFLOW_ENABLED=false
ROBOFLOW_API_KEY=
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_MODEL_ID=idd-octso/3,pedestrian-yldth/4,motorcycle-helmet-pz9xs-qoh78/1,seatbelt-detection-lb1ec-pjbz0/1

# --- SAHI (Sliced Inference) ---
SAHI_ENABLED=false
SAHI_SLICE_HEIGHT=640
SAHI_SLICE_WIDTH=640
SAHI_OVERLAP_RATIO=0.2

# --- Evidence Storage ---
EVIDENCE_DIR=./evidence
EVIDENCE_RETENTION_HOURS=72

# --- Violation Thresholds ---
SPEED_LIMIT_KMH=60
HELMET_CONFIDENCE_THRESHOLD=0.6
PARKING_DURATION_SECONDS=300
WRONG_SIDE_COSINE_THRESHOLD=-0.5
MIN_CONSECUTIVE_FRAMES=5

# --- ANPR ---
ANPR_ENABLED=true
OCR_ENGINE=easyocr
# Options: easyocr, paddleocr
PLATE_REGEX=^[A-Z]{2}\s?\d{1,2}\s?[A-Z]{1,3}\s?\d{4}$

# --- Training ---
TRAINING_OUTPUT_DIR=./training/runs
DEFAULT_EPOCHS=100
DEFAULT_BATCH_SIZE=16
DEFAULT_IMG_SIZE=640

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- VLM (Optional, for complex scene analysis) ---
# VLM_ENABLED=false
# VLM_PROVIDER=openai
# VLM_API_KEY=your-api-key
# VLM_MODEL=gpt-4o
